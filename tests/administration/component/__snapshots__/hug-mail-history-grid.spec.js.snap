exports[`hug-mail-history-grid loads and renders the history (snapshot) 1`] = `
"<div class="hug-mail-history-grid">
  <div class="hug-mail-history-grid__layout">
    <div class="hug-mail-history-grid__list">
      <table class="sw-data-grid-stub" show-selection="false" show-actions="true" plain-appearance="true" identifier="hug-mail-history-grid">
