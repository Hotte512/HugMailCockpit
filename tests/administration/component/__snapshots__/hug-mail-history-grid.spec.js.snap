          <tr class="sw-data-grid__row sw-data-grid__row--0">
            <td>Your invoice</td>
          </tr>
          <tr class="sw-data-grid__row sw-data-grid__row--1">
            <td>Order confirmation</td>
          </tr>
        </tbody><button class="sw-context-menu-item-stub">hug-mail-cockpit.history.actionView</button><button class="sw-context-menu-item-stub">hug-mail-cockpit.history.actionReply</button><button class="sw-context-menu-item-stub">hug-mail-cockpit.history.actionOpenArchive</button>
      </table>
    </div>
    <aside class="hug-mail-history-grid__preview">
