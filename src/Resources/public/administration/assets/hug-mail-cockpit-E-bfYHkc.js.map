{% block sw_customer_detail_content_tab_after %}
    {% parent %}

    <sw-tabs-item
        v-if="hugMailTabVisible"
        class="hug-mail-cockpit__tab"
        :route="{ name: 'sw.customer.detail.hugMails', params: { id: $route.params.id } }"
        :title="$tc('hug-mail-cockpit.tab.label')"
    >
        {{ hugMailTabLabel }}
    </sw-tabs-item>
{% endblock %}
