{% block sw_customer_detail_actions %}
    {% parent %}

    <mt-button
        v-if="hugMailButtonVisible"
        class="hug-mail-cockpit__smart-bar-button"
        variant="secondary"
        size="default"
        @click="hugMailModalOpen = true"
    >
        {{ $tc('hug-mail-cockpit.smartBar.sendMail') }}
    </mt-button>

    <hug-mail-compose-modal
        v-if="hugMailModalOpen"
        :customer-id="$route.params.id"
        @modal-close="hugMailModalOpen = false"
    />
{% endblock %}
